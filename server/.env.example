# ─── FYERS API credentials ───────────────────────────────────────────
# Get these from https://myaccount.fyers.in/
FYERS_APP_ID=your_app_id_here
FYERS_SECRET_ID=your_secret_id_here
# Must exactly match the redirect URL registered on your FYERS app
FYERS_REDIRECT_URL=http://localhost:5173/live-trade
# Account PIN — OPTIONAL but required for UNATTENDED daily token refresh. FYERS access tokens
# expire daily; with the PIN set the server can mint a fresh token from the (~15-day) refresh
# token without a manual re-login, and the live tick feed re-arms itself. Leave blank to require
# a manual reconnect each day. SENSITIVE: storing it enables fully unattended trading — keep it
# in this server-side .env only, never in the frontend or git.
FYERS_PIN=

# Your FYERS user ID (e.g. XR07633), shown in the FYERS app / myaccount.fyers.in. RECOMMENDED:
# without this, any FYERS account that completes login gets a valid session that can hit
# /emergency-stop, change risk config, or read positions on THIS bot. Leave blank only if you
# understand and accept that risk.
OPERATOR_FYERS_ID=

# ─── Server settings ─────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5173

# Secret used to sign/verify session tokens — use a long random string
JWT_SECRET=your_random_secret_key_here
