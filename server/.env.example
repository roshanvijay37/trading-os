# ─── FYERS API credentials ───────────────────────────────────────────
# Get these from https://myaccount.fyers.in/
FYERS_APP_ID=your_app_id_here
FYERS_SECRET_ID=your_secret_id_here
# Must exactly match the redirect URL registered on your FYERS app
FYERS_REDIRECT_URL=http://localhost:5173/live-trade

# ─── Server settings ─────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5173

# Secret used to sign/verify session tokens — use a long random string
JWT_SECRET=your_random_secret_key_here

# ─── Kimi AI (Moonshot) — powers the AI CIO routes ───────────────────
# Get from https://platform.moonshot.cn/
KIMI_API_KEY=your_kimi_api_key_here
# Optional overrides (defaults shown)
KIMI_MODEL=moonshot-v1-8k
KIMI_BASE_URL=https://api.moonshot.cn/v1
