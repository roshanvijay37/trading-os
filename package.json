{
  "name": "trading-os-institutional",
  "version": "2.0.0-institutional",
  "private": true,
  "description": "TradingOS Institutional - Autonomous Quantitative Trading Operating System",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch src/server/main.ts",
    "dev:client": "vite",
    "build": "tsc && vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node dist/server/main.js",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/websocket": "^8.3.1",
    "@tanstack/react-query": "^5.28.0",
    "@tanstack/react-table": "^8.15.0",
    "d3": "^7.9.0",
    "date-fns": "^3.6.0",
    "eventemitter3": "^5.0.1",
    "fastify": "^4.26.2",
    "immer": "^10.0.4",
    "ioredis": "^5.3.2",
    "lightweight-charts": "^4.2.1",
    "lodash": "^4.17.21",
    "lucide-react": "^0.468.0",
    "mathjs": "^12.4.1",
    "ml-matrix": "^6.11.0",
    "nanoid": "^5.0.6",
    "pino": "^8.19.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-grid-layout": "^1.4.4",
    "react-router-dom": "^6.22.3",
    "recharts": "^2.12.3",
    "simple-statistics": "^7.8.3",
    "tsyringe": "^4.8.0",
    "uuid": "^9.0.1",
    "ws": "^8.16.0",
    "zod": "^3.22.4",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/lodash": "^4.17.0",
    "@types/node": "^20.11.30",
    "@types/react": "^18.2.67",
    "@types/react-dom": "^18.2.22",
    "@types/react-grid-layout": "^1.3.5",
    "@types/uuid": "^9.0.8",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.38",
    "reflect-metadata": "^0.2.1",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.7.1",
    "typescript": "^5.4.3",
    "vite": "^5.2.0",
    "vitest": "^1.4.0"
  }
}
